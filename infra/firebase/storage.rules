rules_version = '2';

// Storage is entirely server-mediated via the Admin SDK (mirrors D-002's
// Firestore precedent): no client ever reads or writes Storage directly.
// Company logos are served through short-lived signed URLs generated by the
// API, not public objects.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
