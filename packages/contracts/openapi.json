  "info": {
    "description": "Flacron EnergyVerse API. Single resources are returned directly. Future list responses use `{items: [...], next_cursor: string | null}`; cursors are opaque, `null` means no more pages, and totals are not returned by default.",
    "title": "FEV API",
    "version": "0.8.0"
  },
