{
  "components": {
    "schemas": {
      "CompanyRegistrationRequest": {
        "additionalProperties": false,
        "properties": {
          "company_name": {
            "maxLength": 120,
            "minLength": 2,
            "title": "Company Name",
            "type": "string"
          },
          "display_name": {
            "maxLength": 120,
            "minLength": 2,
            "title": "Display Name",
            "type": "string"
          },
          "email": {
            "maxLength": 320,
            "minLength": 5,
            "title": "Email",
            "type": "string"
          },
          "password": {
            "maxLength": 128,
            "minLength": 8,
            "title": "Password",
            "type": "string"
          }
        },
        "required": [
          "company_name",
          "display_name",
          "email",
          "password"
        ],
        "title": "CompanyRegistrationRequest",
        "type": "object"
      },
      "CompanyRegistrationResponse": {
        "additionalProperties": false,
        "properties": {
          "company_id": {
            "title": "Company Id",
            "type": "string"
          },
          "email": {
            "title": "Email",
            "type": "string"
          },
          "email_verified": {
            "title": "Email Verified",
            "type": "boolean"
          },
          "role_key": {
            "title": "Role Key",
            "type": "string"
          },
          "uid": {
            "title": "Uid",
            "type": "string"
          }
        },
        "required": [
          "uid",
          "email",
          "email_verified",
          "company_id",
          "role_key"
        ],
        "title": "CompanyRegistrationResponse",
        "type": "object"
      },
      "CurrentUser": {
        "additionalProperties": false,
        "properties": {
          "company_id": {
            "title": "Company Id",
            "type": "string"
          },
          "company_name": {
            "title": "Company Name",
            "type": "string"
          },
          "email": {
            "title": "Email",
            "type": "string"
          },
          "email_verified": {
            "title": "Email Verified",
            "type": "boolean"
          },
          "permissions": {
            "items": {
              "type": "string"
            },
            "title": "Permissions",
            "type": "array",
            "uniqueItems": true
          },
          "role_key": {
            "title": "Role Key",
            "type": "string"
          },
          "uid": {
            "title": "Uid",
            "type": "string"
          }
        },
        "required": [
          "uid",
          "email",
          "email_verified",
          "company_id",
          "company_name",
          "role_key",
          "permissions"
        ],
        "title": "CurrentUser",
        "type": "object"
      },
      "DemoGateResponse": {
        "properties": {
          "ok": {
            "const": true,
            "title": "Ok",
            "type": "boolean"
          }
        },
        "required": [
          "ok"
        ],
        "title": "DemoGateResponse",
        "type": "object"
      },
      "ErrorEnvelope": {
        "description": "Stable error contract returned by every API failure.",
        "properties": {
          "details": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "description": "Optional structured JSON object",
            "title": "Details"
          },
          "error": {
            "description": "Stable machine-readable error code",
            "title": "Error",
            "type": "string"
          },
          "message": {
            "description": "Human-readable error summary",
            "title": "Message",
            "type": "string"
          },
          "request_id": {
            "description": "Request correlation identifier",
            "format": "uuid",
            "title": "Request Id",
            "type": "string"
          }
        },
        "required": [
          "error",
          "message",
          "request_id"
        ],
        "title": "ErrorEnvelope",
        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "firestore": {
            "enum": [
              "connected",
              "unavailable",
              "unconfigured"
            ],
            "title": "Firestore",
            "type": "string"
          },
          "service": {
            "const": "fev-api",
            "title": "Service",
            "type": "string"
          },
          "status": {
            "const": "ok",
            "title": "Status",
            "type": "string"
          },
          "timestamp": {
            "format": "date-time",
            "title": "Timestamp",
            "type": "string"
          }
        },
        "required": [
          "service",
          "status",
          "firestore",
          "timestamp"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "ServiceResponse": {
        "properties": {
          "service": {
            "const": "fev-api",
            "title": "Service",
            "type": "string"
          },
          "status": {
            "const": "ok",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "service",
          "status"
        ],
        "title": "ServiceResponse",
        "type": "object"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "Flacron EnergyVerse API. Single resources are returned directly. Future list responses use `{items: [...], next_cursor: string | null}`; cursors are opaque, `null` means no more pages, and totals are not returned by default.",
    "title": "FEV API",
    "version": "0.8.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/": {
      "get": {
        "operationId": "get_root",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Unexpected server error"
          }
        },
        "summary": "Root",
        "tags": [
          "system"
        ]
      }
    },
