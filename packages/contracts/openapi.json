      "DemoGateResponse": {
        "properties": {
          "ok": {
            "const": true,
            "title": "Ok",
            "type": "boolean"
          }
        },
        "required": [
          "ok"
        ],
        "title": "DemoGateResponse",
        "type": "object"
      },
      "ErrorEnvelope": {
        "description": "Stable error contract returned by every API failure.",
        "properties": {
          "details": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "description": "Optional structured JSON object",
            "title": "Details"
          },
          "error": {
            "description": "Stable machine-readable error code",
            "title": "Error",
            "type": "string"
          },
          "message": {
            "description": "Human-readable error summary",
            "title": "Message",
            "type": "string"
          },
          "request_id": {
            "description": "Request correlation identifier",
            "format": "uuid",
            "title": "Request Id",
            "type": "string"
          }
        },
        "required": [
          "error",
          "message",
          "request_id"
        ],
        "title": "ErrorEnvelope",
        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "firestore": {
            "enum": [
              "connected",
              "unavailable",
              "unconfigured"
            ],
            "title": "Firestore",
            "type": "string"
          },
          "service": {
            "const": "fev-api",
            "title": "Service",
            "type": "string"
          },
          "status": {
            "const": "ok",
            "title": "Status",
            "type": "string"
          },
          "timestamp": {
            "format": "date-time",
            "title": "Timestamp",
            "type": "string"
          }
        },
        "required": [
          "service",
          "status",
          "firestore",
          "timestamp"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "ServiceResponse": {
        "properties": {
          "service": {
            "const": "fev-api",
            "title": "Service",
            "type": "string"
          },
          "status": {
            "const": "ok",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "service",
          "status"
        ],
        "title": "ServiceResponse",
        "type": "object"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "scheme": "bearer",
        "type": "http"
      }
    }
