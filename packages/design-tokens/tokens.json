      "enter": [
        0.16,
        1,
        0.3,
        1
      ],
      "exit": [
        0.7,
        0,
        0.84,
        0
      ],
      "emphasized": [
        0.16,
        1,
        0.3,
        1
      ]
    },
    "staggerMs": 55
  }
