  "radius": {
    "none": 0,
    "sm": 2,
    "md": 4,
    "lg": 6,
    "xl": 10,
    "2xl": 14,
    "full": 9999
  },
  "shadow": {
    "sm": "0 1px 0 rgba(2, 6, 23, 0.4)",
    "md": "0 1px 0 rgba(2, 6, 23, 0.5)",
    "lg": "0 2px 0 rgba(2, 6, 23, 0.5)",
    "glow": "0 0 16px rgba(59, 105, 197, 0.35)",
    "glowCritical": "0 0 16px rgba(204, 36, 54, 0.35)"
  },
  "zIndex": {
    "base": 0,
    "raised": 10,
    "dropdown": 100,
    "sticky": 200,
    "overlay": 400,
    "modal": 500,
    "toast": 600,
    "tooltip": 700
  },
  "motion": {
    "duration": {
      "instant": 0,
      "fast": 120,
      "normal": 180,
      "slow": 240,
      "deliberate": 320
