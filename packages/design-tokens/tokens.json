{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "meta": {
    "name": "FEV Industrial Energy",
    "version": "2.1.2",
    "defaultTheme": "dark"
  },
  "color": {
    "primary": {
      "50": "#F1F6FE",
      "100": "#DFEAFD",
      "200": "#BDD4F7",
      "300": "#95B7EC",
      "400": "#6F99DC",
      "500": "#4D7BC5",
      "600": "#3160AA",
      "700": "#17468E",
      "800": "#002865",
      "900": "#001A49"
    },
    "accent": {
      "50": "#FFF2EE",
      "100": "#FEE0D8",
      "200": "#FBC1B2",
      "300": "#F59E87",
      "400": "#EE7A5C",
      "500": "#FB4402",
      "600": "#C93B12",
      "700": "#A62B03",
      "800": "#841F01",
      "900": "#661802",
