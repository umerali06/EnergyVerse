{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "meta": {
    "name": "FEV Industrial Energy",
    "version": "0.7.0",
    "defaultTheme": "dark"
  },
  "color": {
    "primary": {
      "50": "#EFF6FF",
      "100": "#DBEAFE",
      "200": "#BFDBFE",
      "300": "#93C5FD",
      "400": "#60A5FA",
      "500": "#2563EB",
      "600": "#1D4ED8",
      "700": "#1E40AF",
      "800": "#1E3A8A",
      "900": "#172554"
    },
    "accent": {
      "50": "#FFF7ED",
      "100": "#FFEDD5",
      "200": "#FED7AA",
      "300": "#FDBA74",
      "400": "#FB923C",
      "500": "#F97316",
      "600": "#EA580C",
      "700": "#C2410C",
      "800": "#9A3412",
      "900": "#7C2D12"
    },
    "status": {
      "success": "#16A34A",
      "warning": "#F59E0B",
      "critical": "#DC2626",
      "info": "#2563EB"
    },
    "theme": {
      "dark": {
        "background": "#0A0E1A",
        "surface": "#111827",
        "elevated": "#1A2234",
        "border": "#334155",
        "textPrimary": "#F8FAFC",
        "textSecondary": "#CBD5E1",
        "textMuted": "#94A3B8"
      },
      "light": {
        "background": "#F8FAFC",
        "surface": "#FFFFFF",
        "elevated": "#E2E8F0",
        "border": "#CBD5E1",
        "textPrimary": "#0F172A",
        "textSecondary": "#334155",
        "textMuted": "#64748B"
      }
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "Inter",
      "mono": "JetBrains Mono"
    },
    "fontSize": {
      "display": 48,
      "h1": 36,
      "h2": 30,
      "h3": 24,
      "h4": 20,
      "h5": 18,
      "h6": 16,
      "bodyLarge": 16,
      "body": 14,
      "bodySmall": 12,
      "caption": 11
    },
    "lineHeight": {
      "tight": 1.15,
      "heading": 1.25,
      "body": 1.5,
      "relaxed": 1.65
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "spacing": {
    "0": 0,
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "5": 20,
    "6": 24,
    "8": 32,
    "10": 40,
    "12": 48,
    "16": 64,
    "20": 80,
    "24": 96
  },
  "radius": {
    "none": 0,
    "sm": 4,
    "md": 8,
    "lg": 12,
    "xl": 16,
    "2xl": 24,
    "full": 9999
  },
  "shadow": {
    "sm": "0 1px 2px rgba(2, 6, 23, 0.35)",
    "md": "0 8px 20px rgba(2, 6, 23, 0.32)",
    "lg": "0 16px 40px rgba(2, 6, 23, 0.38)",
    "glow": "0 0 24px rgba(37, 99, 235, 0.28)"
  },
  "zIndex": {
    "base": 0,
    "raised": 10,
    "dropdown": 100,
    "sticky": 200,
    "overlay": 400,
    "modal": 500,
    "toast": 600,
    "tooltip": 700
  },
  "motion": {
    "duration": {
      "instant": 0,
      "fast": 120,
      "normal": 200,
      "slow": 320,
      "deliberate": 480
    },
    "easing": {
      "standard": [0.2, 0, 0, 1],
      "enter": [0, 0, 0.2, 1],
      "exit": [0.4, 0, 1, 1],
      "emphasized": [0.2, 0.8, 0.2, 1]
    },
    "staggerMs": 55
  }
}
