# FEV Admin Environment Variables
# Copy to .env.local and fill in values

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Firebase Web client config (safe public identifiers; never add Admin credentials here)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional public continue URL for Firebase verification/reset actions.
# Unset keeps Firebase's hosted default flow.
NEXT_PUBLIC_AUTH_ACTION_URL=
