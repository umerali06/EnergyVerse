# FEV API Environment Variables
# Copy to .env and fill in values

APP_NAME=FEV API
FEV_DEBUG=false

# Firebase Admin SDK (never commit real credentials)
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_CREDENTIALS_B64=

# Firebase Auth (real-auth seed/integration only)
FIREBASE_WEB_API_KEY=
SEED_DEMO_PASSWORD=

# Optional until Phase 1 auth screens exist; unset uses Firebase defaults
AUTH_ACTION_URL=
