# FEV API Environment Variables
# Copy to .env and fill in values

APP_NAME=FEV API
FEV_DEBUG=false

# Firebase Admin SDK (never commit real credentials)
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_CREDENTIALS_B64=

# Firebase Storage (company logo upload; optional -- falls back to
# "<FIREBASE_PROJECT_ID>.appspot.com" if unset)
FIREBASE_STORAGE_BUCKET=

# Firebase Auth (real-auth seed/integration only)
FIREBASE_WEB_API_KEY=
SEED_DEMO_PASSWORD=
# Fresh throwaway inbox for the destructive, local-only signup verification test
REAL_SIGNUP_TEST_EMAIL=

# Optional until Phase 1 auth screens exist; unset uses Firebase defaults
AUTH_ACTION_URL=
